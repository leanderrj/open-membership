---
import BaseLayout from './BaseLayout.astro';

export interface SpecCrumb {
  href: string;
  label: string;
}

interface Props {
  title: string;
  pageTitle?: string;
  description?: string;
  summary: string;
  meta?: string;
  crumbs?: SpecCrumb[];
  toc?: Array<{ depth: number; slug: string; text: string }>;
}

const {
  title,
  pageTitle,
  description,
  summary,
  meta,
  crumbs = [],
  toc = [],
} = Astro.props;

const seoTitle = pageTitle ?? `${title} · Open Membership RSS`;
const stripAnchor = (s: string) => s.replace(/[¶#]+\s*$/, '').trim();

const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();
const ldjson = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: title,
  name: title,
  abstract: summary,
  description: description ?? summary,
  url: pageUrl,
  inLanguage: 'en',
  isPartOf: {
    '@type': 'TechArticle',
    name: 'Open Membership RSS',
    url: 'https://openmembership.org/spec/',
  },
  author: {
    '@type': 'Organization',
    name: 'Open Membership Working Group',
    url: 'https://openmembership.org/',
  },
  license: 'https://creativecommons.org/licenses/by/4.0/',
  proficiencyLevel: 'Expert',
  dependencies: 'RFC 8615; RFC 9728; W3C Verifiable Credentials Data Model 2.0; W3C Decentralized Identifiers 1.0; W3C BBS Cryptosuite',
};
---
<BaseLayout title={seoTitle} description={description ?? summary}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(ldjson)} />
    <meta property="og:type" content="article" />
    <meta property="article:section" content="Specification" />
  </Fragment>
  <main class="bg-paper">
    <article class="mx-auto max-w-prose px-6 pt-12 pb-20">
      {crumbs.length > 0 && (
        <nav class="text-xs uppercase tracking-wider text-ink-mute mb-6 flex flex-wrap gap-x-2">
          {crumbs.map((c, i) => (
            <span>
              {i > 0 && <span class="px-1">/</span>}
              <a href={c.href} class="hover:text-accent no-underline">{c.label}</a>
            </span>
          ))}
        </nav>
      )}

      <h1 class="font-sans text-3xl md:text-4xl font-semibold tracking-tight text-ink mb-4">{title}</h1>

      <div class="border-l-2 border-accent bg-accent-soft/30 pl-4 py-2 text-ink-soft text-[0.95rem] mb-2 rounded-sm">
        <p class="m-0">{summary}</p>
      </div>

      {meta && (
        <p class="text-xs uppercase tracking-wider text-ink-mute mt-3 mb-6">{meta}</p>
      )}

      {toc.length > 0 && (
        <nav class="bg-paperAlt rounded p-5 my-8 text-sm">
          <h2 class="text-xs uppercase tracking-wider text-ink-mute m-0 mb-3">Contents</h2>
          <ul class="m-0 p-0 list-none space-y-1">
            {toc.map((h) => (
              <li class={h.depth === 3 ? 'pl-4' : h.depth === 4 ? 'pl-8' : ''}>
                <a href={`#${h.slug}`} class="text-ink-soft no-underline hover:text-accent hover:underline">{stripAnchor(h.text)}</a>
              </li>
            ))}
          </ul>
        </nav>
      )}

      <div class="prose prose-spec max-w-none" data-pagefind-body>
        <span data-pagefind-meta={`title:${title}`} hidden />
        <span data-pagefind-meta={`summary:${summary}`} hidden />
        <slot />
      </div>

      <aside class="mt-16 pt-8 border-t border-ink-line text-sm text-ink-soft" aria-label="Conformance levels at a glance">
        <h2 class="text-xs uppercase tracking-wider text-ink-mute mb-3">Conformance levels at a glance</h2>
        <p class="m-0 mb-3 text-ink-mute">Eight cumulative conformance levels. An implementation at level <em>N</em> supports everything at levels 1 through <em>N</em>. Most readers and publishers target Level 1, 2, or 5.</p>
        <dl class="grid sm:grid-cols-2 gap-x-6 gap-y-1 m-0">
          <div><dt class="inline font-semibold text-ink">Level 1</dt><dd class="inline m-0"> · parsing the namespace and previews</dd></div>
          <div><dt class="inline font-semibold text-ink">Level 2</dt><dd class="inline m-0"> · URL-token authentication and unlocks</dd></div>
          <div><dt class="inline font-semibold text-ink">Level 3</dt><dd class="inline m-0"> · OAuth bearer + DPoP, time windows, SCIM groups</dd></div>
          <div><dt class="inline font-semibold text-ink">Level 4</dt><dd class="inline m-0"> · Verifiable Credential presentation (OM-VC)</dd></div>
          <div><dt class="inline font-semibold text-ink">Level 5</dt><dd class="inline m-0"> · commerce: PSPs, offers, checkout, entitlements</dd></div>
          <div><dt class="inline font-semibold text-ink">Level 6</dt><dd class="inline m-0"> · value-for-value, recipient splits, Lightning</dd></div>
          <div><dt class="inline font-semibold text-ink">Level 7</dt><dd class="inline m-0"> · pseudonymous mode (OM-VC-SD with BBS+)</dd></div>
          <div><dt class="inline font-semibold text-ink">Level 8</dt><dd class="inline m-0"> · cross-publisher bundle aggregation</dd></div>
        </dl>
        <p class="m-0 mt-3 text-ink-mute">Full effort estimates and per-level requirements: <a href="/docs/featureset/" class="text-accent">Featureset and Conformance Levels</a>.</p>
      </aside>
    </article>
  </main>
</BaseLayout>
