---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { docs, docHref } from '../../data/spec-meta.ts';

const ordered = [...docs].sort((a, b) => a.order - b.order);
---
<BaseLayout title="Project documents · Open Membership RSS" description="Featureset, governance, reader architecture, and related work.">
  <main>
    <section class="border-b border-ink-line">
      <div class="mx-auto max-w-prose px-6 py-16">
        <p class="text-xs uppercase tracking-wider text-ink-mute mb-3">Project documents</p>
        <h1 class="font-sans text-3xl md:text-4xl font-semibold tracking-tight text-ink mb-4">Open Membership RSS</h1>
        <p class="text-ink-soft text-lg max-w-2xl">
          Non-normative documents that accompany the specification: featureset and conformance levels, governance, reader architecture, and related work.
        </p>
      </div>
    </section>

    <section>
      <div class="mx-auto max-w-prose px-6 py-12">
        <ul class="list-none p-0 m-0">
          {ordered.map((d) => (
            <li class="border-t border-ink-line py-5 last:border-b">
              <a href={docHref(d)} class="font-sans font-semibold text-lg text-ink no-underline hover:text-accent">{d.title}</a>
              <p class="m-0 mt-1 text-ink-soft text-[0.95rem]">{d.summary}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>
  </main>
</BaseLayout>
