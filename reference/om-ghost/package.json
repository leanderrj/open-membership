{
  "name": "om-ghost",
  "version": "0.1.0",
  "description": "Reference Ghost implementation of Open Membership RSS",
  "license": "MIT",
  "type": "module",
  "main": "dist/service/index.js",
  "bin": {
    "om-ghost": "dist/service/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch service/index.ts",
    "start": "node dist/service/index.js",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "test": "node --import tsx --test --test-reporter=spec test/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.1",
    "better-sqlite3": "^11.5.0",
    "hono": "^4.6.12",
    "jose": "^5.9.6",
    "pino": "^9.5.0",
    "stripe": "^17.3.1",
    "xmlbuilder2": "^3.1.1",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260429.1",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "wrangler": "^3.86.1"
  }
}
