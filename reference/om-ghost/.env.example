# Sidecar bind
PORT=4000
HOST=0.0.0.0
PUBLIC_URL=https://publisher.example

# Logging
LOG_LEVEL=info    # trace|debug|info|warn|error|fatal

# Ghost Admin API (generate from Ghost Admin → Integrations → Custom Integrations)
GHOST_URL=https://publisher.example
GHOST_ADMIN_KEY=id:secret
GHOST_CONTENT_KEY=abcdef0123456789abcdef01

# Stripe — this MUST be the same account Ghost is already connected to
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Signing keys (32 chars min; 64 hex recommended).
# Generate both with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OM_FEED_TOKEN_KEY=
OM_JWT_SIGNING_KEY=

# Filesystem paths
OM_CONFIG_PATH=./om-config.yaml
OM_STATE_DIR=./state   # holds idempotency.sqlite

# CORS — comma-separated origins allowed to hit /api/om/*. Leave empty
# to reflect whatever Origin the request carried (useful for dev; lock
# down in production).
OM_CORS_ORIGINS=
