# Sidecar bind
PORT=4000
PUBLIC_URL=https://publisher.example

# Ghost Admin API (generate from Ghost Admin → Integrations → Custom Integrations)
GHOST_URL=https://publisher.example
GHOST_ADMIN_KEY=id:secret

# Stripe — this MUST be the same account Ghost is already connected to
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Signing keys
# Used to HMAC feed tokens derived from Ghost member UUIDs.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OM_FEED_TOKEN_KEY=

# Used to sign JWTs the sidecar issues to readers on /api/om/token.
# Same generator as above.
OM_JWT_SIGNING_KEY=

# Optional: path to om-config.yaml. Defaults to ./om-config.yaml next to the service.
OM_CONFIG_PATH=./om-config.yaml
