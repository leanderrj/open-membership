<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ title or "Publisher Example" }}</title>
    <link rel="alternate" type="application/rss+xml" title="Public feed" href="/public.xml" />
    <link rel="alternate" type="application/json" title="Open Membership discovery" href="/.well-known/open-membership" />
  </head>
  <body>
    <header>
      <h1><a href="/">Publisher Example</a></h1>
      <nav>
        <a href="/">Home</a>
        <a href="/public.xml">Public feed</a>
      </nav>
    </header>
    <main>
      {{ content | safe }}
    </main>
    <footer>
      <p>Open Membership RSS reference &mdash; static-site publisher.</p>
    </footer>
  </body>
</html>
